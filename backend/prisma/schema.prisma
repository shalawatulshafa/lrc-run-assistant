generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  runs         Run[]
}

model Run {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  title             String
  targetPattern     String
  avgLrc            String?
  date              DateTime @default(now())
  sessionNumber     Int?
  duration          String
  avgSpm            Int
  compliance        Int
  rawLrcData        Json?
  // Distribusi pola dari SEMUA siklus (basis sama dengan compliance),
  // dipakai histogram di frontend. Berbeda dari rawLrcData yang sudah
  // terfilter outlier sumbu-Y untuk keperluan chart garis. Null untuk
  // sesi lama sebelum field ini ditambahkan.
  patternDistribution Json?
  rawCsv            String?
  // Metrik baru dari format CSV dengan step=0 transition rows.
  // Null untuk data lari lama (sebelum firmware update yang emit step=0).
  avgLag            Float?
  phaseDrift        Float?
  consistencyScore  Int?

  @@unique([userId, date, sessionNumber])
}